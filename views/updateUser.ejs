<!-- views/updateUser.ejs -->
<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>
    <%- include("partials/errors.ejs") %>
    <form action="/<%= user.id %>/update" method="POST">
      <input
        type="text"
        name="firstName"
        value="<%= user.firstName %>"
        required
      />
      <input
        type="text"
        name="lastName"
        value="<%= user.lastName %>"
        required
      />
      <input
        type="email"
        name="email"
        id="email"
        required
        value="<%= user.email %>"
      />
      <input
        type="number"
        name="age"
        id="age"
        required
        min="18"
        max="120"
        value="<%= user.age %>"
      />
      <textarea
        name="bio"
        id="bio"
        maxlength="200"
        value="<%= user.bio %>"
      ></textarea>
      <button type="submit">Submit</button>
    </form>
    <a href="/">Back to home</a>
  </body>
</html>
